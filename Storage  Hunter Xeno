    local PlotEvents = events:WaitForChild("Plot")
    local PlaceStockItem = PlotEvents:WaitForChild("PlaceStockItem")
    local GetPlayerInventory = events:WaitForChild("Inventory"):WaitForChild("GetPlayerInventory")
    local ItemsData = require(ReplicatedStorage.Modules.Items)
    local MutatorModule = require(ReplicatedStorage.Modules.MutatorModule)
    local attemptedPlacements = {}
    
    while task.wait(4) do
        if _G.AHScanner_RunID ~= myRunID then break end
        if gConfig.autoSellStore and PlaceStockItem then
            pcall(function()
                -- Get player inventory first
                local inv = GetPlayerInventory:InvokeServer()
                if not inv or not next(inv) then return end
                
                -- Find player's plot
                local plots = workspace:FindFirstChild("_Plots")
                if not plots then return end
                local myPlot = nil
                for _, p in ipairs(plots:GetChildren()) do
                    if p:GetAttribute("OwnerUserId") == game:GetService("Players").LocalPlayer.UserId then
                        myPlot = p
                        break
                    end
                end
                if not myPlot then return end
                
                -- Get empty slots
                local emptySlots = {}
                local Stock = myPlot:FindFirstChild("Stock")
                local occupied = {}
                if Stock then
                    for _, item in ipairs(Stock:GetChildren()) do
                        local shelfGuid = item:GetAttribute("ShelfGUID")
                        local snapName = item:GetAttribute("SnapPointName")
                        if shelfGuid and snapName then
                            occupied[shelfGuid .. "_" .. snapName] = true
                        end
                    end
                end
                
                -- Update permanent Furniture Cache if we are close to our plot and it is loaded
                local Furniture = myPlot:FindFirstChild("Furniture")
                if Furniture and #Furniture:GetChildren() > 0 then
                    local tempCache = {}
                    for _, shelf in ipairs(Furniture:GetDescendants()) do
                        if shelf:IsA("Model") and shelf:GetAttribute("GUID") then
                            local shelfGuid = shelf:GetAttribute("GUID")
                            for _, att in ipairs(shelf:GetDescendants()) do
                                if att:IsA("Attachment") and att.Name:match("^SnapPoint") then
                                    table.insert(tempCache, {
                                        shelfName = shelf.Name,
                                        shelfGuid = shelfGuid,
                                        snapName = att.Name,
                                        worldCFrame = att.WorldCFrame
                                    })
                                end
                            end
                        end
                    end
                    if #tempCache > 0 then
                        _G.PlotFurnitureCache = tempCache
                    end
                end
                
                _G.PlotFurnitureCache = _G.PlotFurnitureCache or {}
                if #_G.PlotFurnitureCache == 0 then
                    abLog("ℹ️ Auto-Place: Please stand near your shop once to cache shelf slots!", C.orange)
                    return
                end
                
                -- Get empty slots using the cache
                for _, cachedSlot in ipairs(_G.PlotFurnitureCache) do
                    if not occupied[cachedSlot.shelfGuid .. "_" .. cachedSlot.snapName] then
                        table.insert(emptySlots, {
                            shelfName = cachedSlot.shelfName,
                            shelfGuid = cachedSlot.shelfGuid,
                            snapName = cachedSlot.snapName,
                            targetCFrame = cachedSlot.worldCFrame
                        })
                    end
                end
                
                -- If no empty slots, just wait for next cycle (items may sell and free slots)
                if #emptySlots == 0 then
                    abLog("🕐 All shelves full, waiting for slots...", C.textMuted)
                    return
                end
                
                -- Helper function to check if item config indicates a Large/Giant item
                local function isLargeItem(conf)
                    if not conf then return false end
                    local size = conf.Size or conf.ShelfSize or conf.ItemSize or conf.ItemType or ""
                    if typeof(size) == "string" then
                        size = size:lower()
                        if size:find("large") or size:find("huge") or size:find("giant") or size:find("big") then
                            return true
                        end
                    end
                    local category = (conf.Category or conf.Type or ""):lower()
                    if typeof(category) == "string" then
                        -- Structure items (fences, large props) always go on podiums
                        if category:find("large") or category:find("giant") or category:find("podium") or category:find("structure") then
                            return true
                        end
                    end
                    return false
                end
                
                for guid, data in pairs(inv) do
                    if not gConfig.autoSellStore then break end
                    if #emptySlots == 0 then break end -- All slots used this cycle
                    
                    -- Skip items processing in workshops
                    if data.StartTime or data.Grade == "WorkInProgress" or data.CleanMutation == "WorkInProgress" or data.Condition == "WorkInProgress" or data.Opened then
                        continue
                    end
                    
                    local itemConf = ItemsData[tostring(data.ItemId)] or ItemsData[tonumber(data.ItemId)]
                    if itemConf then
                        local name = itemConf.Name or ""
                        local category = (itemConf.Category or ""):lower()
                        
                        -- Skip trophies and gavel items (by name or category)
                        if string.lower(name):find("trophy") or category == "trophy" or string.lower(name):find("gavel") then
                            abLog("⏭️ Auto‑Place: Skip trophy/gavel " .. name, C.textMuted)
                            continue
                        end
                        
                        -- Skip accessories (by category)
                        if category:find("accessory") or category:find("accessories") then
                            abLog("⏭️ Auto‑Place: Skip accessory " .. name, C.textMuted)
                            continue
                        end
                        
                        local large = isLargeItem(itemConf)
                        
                        -- Find first matching slot
                        local foundIdx = nil
                        for i, slot in ipairs(emptySlots) do
                            local isPodium = slot.shelfName:lower():find("podium")
                            if (large and isPodium) or (not large) then
                                foundIdx = i
                                break
                            end
                        end
                        
                        if foundIdx then
                            local slot = table.remove(emptySlots, foundIdx) -- Consume slot
                            local rotY = itemConf.ShelfRotationY or 0
                            local targetCFrame = slot.targetCFrame * CFrame.Angles(0, math.rad(rotY), 0)
                            local price = MutatorModule:CalculatePriceForEntry(itemConf.BasePrice or 0, data)
                            
                            -- Register placement attempt
                            attemptedPlacements[guid] = { Name = name }
                            
                            -- Place it!
                            abLog("⚡ Auto‑Place: Placing " .. name .. " for $" .. math.floor(price), C.green)
                            PlaceStockItem:FireServer(guid, tostring(data.ItemId), targetCFrame, price, slot.shelfGuid, slot.snapName)
                            task.wait(0.5)
                        else
                            abLog("⏭️ Auto‑Place: No matching shelf slot for " .. name, C.textMuted)
                        end
                    else
                        abLog("⏭️ Auto‑Place: Unknown item ID " .. tostring(data.ItemId), C.textMuted)
                    end
                end
            end)
        end
    end
end)
    
