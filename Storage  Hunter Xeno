local DRIVEWAY_FORWARD_OFFSET = 90
local DRIVEWAY_HEIGHT_OFFSET = 5
local _G_calibratedUnpackCF = _G.AHScanner_UnpackCF or nil

local function getTpTarget()
    local plots = workspace:FindFirstChild("_Plots")
    local myPlot = nil
    if plots then
        for _, p in ipairs(plots:GetChildren()) do
            if p:GetAttribute("OwnerUserId") == LocalPlayer.UserId then
                myPlot = p
                break
            end
        end
    end
    local unpackZone = workspace:FindFirstChild("UnpackZone", true)
    if unpackZone then
        local uzCF = unpackZone:IsA("Model") and unpackZone:GetPivot() or unpackZone.CFrame
        _G.AHScanner_UnpackCF = uzCF
        _G_calibratedUnpackCF = uzCF
        return uzCF + Vector3.new(0, DRIVEWAY_HEIGHT_OFFSET, 0)
    end
    if _G_calibratedUnpackCF then
        return _G_calibratedUnpackCF + Vector3.new(0, DRIVEWAY_HEIGHT_OFFSET, 0)
    end
    if myPlot then
        local base = myPlot:FindFirstChild("Base")
        local floor = base and (base:FindFirstChild("Floor") or base:FindFirstChildWhichIsA("BasePart"))
        if floor then
            return floor.CFrame * CFrame.new(0, DRIVEWAY_HEIGHT_OFFSET, -DRIVEWAY_FORWARD_OFFSET)
        end
    end
    if myPlot then
        local plotCF = PLOT_FLOOR_CFRAMES[myPlot.Name]
        if plotCF then
            return plotCF * CFrame.new(0, DRIVEWAY_HEIGHT_OFFSET, -DRIVEWAY_FORWARD_OFFSET)
        end
    end
    return nil
end

local function flatCF(cf, heightOffset, yawOffset)
    heightOffset = heightOffset or 0
    yawOffset = yawOffset or 0
    local pos = cf.Position + Vector3.new(0, heightOffset, 0)
    local look = cf.LookVector
    local yaw = math.atan2(-look.X, -look.Z) + yawOffset
    return CFrame.new(pos) * CFrame.Angles(0, yaw, 0)
end

