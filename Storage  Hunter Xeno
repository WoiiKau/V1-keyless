function renderWorkshop(shopKey)
    for _, c in ipairs(leftCol:GetChildren()) do if not c:IsA("UIListLayout") then c:Destroy() end end
    for _, c in ipairs(rightCol:GetChildren()) do if not c:IsA("UIListLayout") then c:Destroy() end end
    activeTimersList = {}
    
    local cfg = SHOPS[shopKey]
    if not cfg then return end

    local function refreshWorkshopView()
        if activeTab and activeTab.name == "Workshops" and activeShopKey == shopKey then
            renderWorkshop(shopKey)
        end
    end

    -- Eligible Inventory items loading
    task.spawn(function()
        local ok, res = pcall(cfg.getEligible)
        if not ok or not res or not res.items then 
            make("TextLabel", { Text = "Failed to load items.", TextSize = 9, TextColor3 = COLORS.Red, Font = Enum.Font.Gotham, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 20) }, leftCol)
            return 
        end
        local items = res.items
        if #items == 0 then 
            make("TextLabel", { Text = cfg.itemEmpty, TextSize = 8, TextColor3 = COLORS.TextDim, Font = Enum.Font.Gotham, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 40), TextWrapped = true }, leftCol)
            return 
        end
        
        local selectedStroke = nil
        for idx, item in ipairs(items) do
            local data = item.data
            local rawName = data.ItemId or "Unknown"
            local rar = data.Rarity or "Common"
            local mut = data.Mutator or "None"
            local grade = data.Grade or 0
            local cond = data.Condition or 100
            local realName, calcVal, finalRar = calcItemValue(rawName, rar, mut, grade, cond)
            
            local card = make("TextButton", { Size = UDim2.new(1, -2, 0, 28), BackgroundColor3 = COLORS.BG, Text = "", AutoButtonColor = false }, leftCol)
            corner(5, card); local cStroke = stroke(1, COLORS.Border, card)
            
            make("TextLabel", { Text = realName, TextSize = 8, TextColor3 = COLORS.Text, Font = Enum.Font.GothamBold, BackgroundTransparency = 1, Position = UDim2.new(0, 6, 0, 2), Size = UDim2.new(1, -12, 0, 12), TextXAlignment = Enum.TextXAlignment.Left, TextTruncate = Enum.TextTruncate.AtEnd }, card)
            make("TextLabel", { Text = finalRar .. (mut ~= "None" and (" • " .. mut) or ""), TextSize = 7, TextColor3 = RARITY_COL[finalRar] or COLORS.TextDim, Font = Enum.Font.GothamMedium, BackgroundTransparency = 1, Position = UDim2.new(0, 6, 0, 14), Size = UDim2.new(1, -12, 0, 12), TextXAlignment = Enum.TextXAlignment.Left }, card)
            
            if selectedItems[shopKey] and selectedItems[shopKey].guid == item.guid then 
                cStroke.Color = COLORS.Accent
                cStroke.Thickness = 1.4
                selectedStroke = cStroke 
            end
            
            card.MouseButton1Click:Connect(function()
                if selectedStroke then selectedStroke.Color = COLORS.Border; selectedStroke.Thickness = 1 end
                cStroke.Color = COLORS.Accent; cStroke.Thickness = 1.4; selectedStroke = cStroke
                selectedItems[shopKey] = item
            end)
        end
    end)

    -- Shop Slots loading
    task.spawn(function()
        local ok, res = pcall(cfg.getSlots)
        if not ok or not res then 
            make("TextLabel", { Text = "Failed to load slots.", TextSize = 9, TextColor3 = COLORS.Red, Font = Enum.Font.Gotham, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 20) }, rightCol)
            return 
        end
        
        local unlockedCount = res.unlockedCount or 1
        local slots = res.slots or {}
        
        for slotIndex = 1, cfg.maxSlots do
            local slotData = slots[tostring(slotIndex)]
            local card = make("Frame", { Size = UDim2.new(1, -2, 0, 68), BackgroundColor3 = COLORS.BG }, rightCol)
            corner(6, card); stroke(1, COLORS.Border, card)
            make("TextLabel", { Text = "Slot #" .. slotIndex, TextSize = 8, TextColor3 = COLORS.TextDim, Font = Enum.Font.GothamBold, BackgroundTransparency = 1, Position = UDim2.new(0, 8, 0, 4), Size = UDim2.new(0.5, 0, 0, 12), TextXAlignment = Enum.TextXAlignment.Left }, card)
            
            if slotIndex > unlockedCount then
                make("TextLabel", { Text = "LOCKED", TextSize = 9, TextColor3 = COLORS.Red, Font = Enum.Font.GothamBold, BackgroundTransparency = 1, Position = UDim2.new(0, 8, 0, 20), Size = UDim2.new(0.5, 0, 0, 14), TextXAlignment = Enum.TextXAlignment.Left }, card)
                local unlockBtn = make("TextButton", { Text = "Unlock", TextSize = 8, Font = Enum.Font.GothamBold, TextColor3 = COLORS.Gold, BackgroundColor3 = COLORS.Card, Position = UDim2.new(0.6, 0, 0.5, -10), Size = UDim2.new(0.4, -6, 0, 20), AutoButtonColor = false }, card)
                corner(5, unlockBtn); stroke(1.2, COLORS.Gold, unlockBtn)
                unlockBtn.MouseButton1Click:Connect(function() 
                    task.spawn(function() 
                        pcall(function() 
                            if cfg.unlockSlot(slotIndex) then 
                                refreshWorkshopView() 
                            end 
                        end) 
                    end) 
                end)
            elseif not slotData then
                make("TextLabel", { Text = "EMPTY", TextSize = 9, TextColor3 = COLORS.TextDim, Font = Enum.Font.GothamBold, BackgroundTransparency = 1, Position = UDim2.new(0, 8, 0, 20), Size = UDim2.new(0.5, 0, 0, 14), TextXAlignment = Enum.TextXAlignment.Left }, card)
                local startBtn = make("TextButton", { Text = "Start", TextSize = 8, Font = Enum.Font.GothamBold, TextColor3 = COLORS.Green, BackgroundColor3 = COLORS.Card, Position = UDim2.new(0.6, 0, 0.5, -10), Size = UDim2.new(0.4, -6, 0, 20), AutoButtonColor = false }, card)
                corner(5, startBtn); stroke(1.2, COLORS.Green, startBtn)
                startBtn.MouseButton1Click:Connect(function()
                    local chosen = selectedItems[shopKey]
                    if not chosen then return end
                    startBtn.Text = "Starting..."
                    task.spawn(function() 
                        pcall(function() 
                            local res = cfg.startWork(slotIndex, chosen.guid, chosen.source, chosen.vehicleGUID)
                            if res and res.success then 
                                selectedItems[shopKey] = nil
                                refreshWorkshopView() 
                            else 
                                startBtn.Text = "Start" 
                            end 
                        end) 
                    end)
                end)
            else
                local itemEntry = slotData.Item or slotData.ItemData or slotData.Entry or {}
                local rawItemName = itemEntry.ItemName or itemEntry.Name or "Processing Item"
                local realItemName, _ = calcItemValue(rawItemName, "Common", "None", 0, 100)
                
                make("TextLabel", { Text = realItemName, TextSize = 9, TextColor3 = COLORS.Text, Font = Enum.Font.GothamBold, BackgroundTransparency = 1, Position = UDim2.new(0, 8, 0, 18), Size = UDim2.new(0.6, 0, 0, 14), TextXAlignment = Enum.TextXAlignment.Left, TextTruncate = Enum.TextTruncate.AtEnd }, card)
                
                local elapsed = workspace:GetServerTimeNow() - (slotData.StartTime or workspace:GetServerTimeNow())
                local remaining = (slotData.Duration or 0) - elapsed
                
                if remaining > 0 and not slotData.Repaired and not slotData.Washed and not slotData.Grade and not slotData.Opened then
                    local tBarBg = make("Frame", { Size = UDim2.new(0.55, 0, 0, 4), Position = UDim2.new(0, 8, 0, 36), BackgroundColor3 = COLORS.Card, BorderSizePixel = 0 }, card); corner(2, tBarBg)
                    local tBarFill = make("Frame", { Size = UDim2.fromScale(math.clamp(elapsed / (slotData.Duration or 1), 0, 1), 1), BackgroundColor3 = COLORS.Accent, BorderSizePixel = 0 }, tBarBg); corner(2, tBarFill)
                    local timeLbl = make("TextLabel", { Text = "0:00", TextSize = 9, TextColor3 = COLORS.Gold, Font = Enum.Font.GothamBold, BackgroundTransparency = 1, Position = UDim2.new(0, 8, 0, 44), Size = UDim2.new(0.55, 0, 0, 14), TextXAlignment = Enum.TextXAlignment.Left }, card)
                    
                    table.insert(activeTimersList, { bar = tBarFill, lbl = timeLbl, startTime = slotData.StartTime or workspace:GetServerTimeNow(), duration = slotData.Duration or 30, card = card, onComplete = refreshWorkshopView })
                    
                    local skipBtn = make("TextButton", { Text = "Skip", TextSize = 8, Font = Enum.Font.GothamBold, TextColor3 = COLORS.Purple, BackgroundColor3 = COLORS.Card, Position = UDim2.new(0.6, 0, 0.5, -10), Size = UDim2.new(0.4, -6, 0, 20), AutoButtonColor = false }, card)
                    corner(5, skipBtn); stroke(1.2, COLORS.Purple, skipBtn)
                    skipBtn.MouseButton1Click:Connect(function() 
                        task.spawn(function() 
                            pcall(function() cfg.speedUp(slotIndex) end)
                            refreshWorkshopView() 
                        end) 
                    end)
                else
                    local btnText, btnColor, action = "Claim", COLORS.Green, "claim"
                    if shopKey == "Wash" and not slotData.Washed then btnText, btnColor, action = "Collect", COLORS.Purple, "collectWash"
                    elseif shopKey == "Repair" and not slotData.Repaired then btnText, btnColor, action = "Collect", COLORS.Purple, "collectRepair"
                    elseif shopKey == "Grading" and not slotData.Grade then btnText, btnColor, action = "Roll", COLORS.Purple, "rollGrade"
                    elseif shopKey == "Locksmith" and not slotData.Opened then btnText, btnColor, action = "Open", COLORS.Orange, "openSafe" end
                    
                    if slotData.Grade then realItemName = realItemName .. " (" .. tostring(slotData.Grade) .. " ⭐)" elseif slotData.CleanMutation then realItemName = realItemName .. " (" .. tostring(slotData.CleanMutation) .. ")" end
                    
                    local actionBtn = make("TextButton", { Text = btnText, TextSize = 8, Font = Enum.Font.GothamBold, TextColor3 = btnColor, BackgroundColor3 = COLORS.Card, Position = UDim2.new(0.6, 0, 0.5, -10), Size = UDim2.new(0.4, -6, 0, 20), AutoButtonColor = false }, card)
                    corner(5, actionBtn); stroke(1.2, btnColor, actionBtn)
                    actionBtn.MouseButton1Click:Connect(function()
                        actionBtn.Text = "Claiming..."
                        task.spawn(function()
                            local success, err = pcall(function()
                                if action == "claim" then
                                    local res = cfg.claimWork(slotIndex)
                                    local function deepFind(t, keys)
                                        if type(t) ~= "table" then return nil end
                                        for k, v in pairs(t) do
                                            for _, key in ipairs(keys) do
                                                if string.lower(tostring(k)) == string.lower(key) then return v end
                                            end
                                            if type(v) == "table" then
                                                local found = deepFind(v, keys)
                                                if found then return found end
                                            end
                                        end
                                        return nil
                                    end
                                    local grade = deepFind(res, {"grade", "stars"}) or deepFind(slotData, {"grade", "stars"})
                                    local mut = deepFind(res, {"cleanmutation", "mutator", "mutation"}) or deepFind(slotData, {"cleanmutation", "mutator", "mutation"})
                                    local cond = deepFind(res, {"condition", "health", "durability"}) or deepFind(slotData, {"condition", "health", "durability"})
                                    
                                    local resultStr = ""
                                    if shopKey == "Grading" then
                                        if grade then resultStr = "\\nStars: " .. tostring(grade) .. " ⭐" end
                                    elseif shopKey == "Wash" then
                                        if mut then resultStr = "\\nMutation: " .. tostring(mut) end
                                    elseif shopKey == "Repair" then
                                        if cond then resultStr = "\\nCondition: " .. tostring(cond) .. "%" end
                                    end
                                    showWorkshopPopup("Claimed!" .. resultStr, COLORS.Green)
                                elseif action == "collectWash" then
                                    local res = EventsObj:WaitForChild("Wash"):WaitForChild("CollectWash"):InvokeServer(slotIndex)
                                    local mut = type(res) == "table" and (res.CleanMutation or res.Mutator or res.Mutation or res.Result)
                                    showWorkshopPopup(mut and "Washed! Mutation: " .. tostring(mut) or "Washed successfully!", COLORS.Green)
                                elseif action == "collectRepair" then
                                    local res = EventsObj:WaitForChild("Repair"):WaitForChild("CollectRepair"):InvokeServer(slotIndex)
                                    local cond = type(res) == "table" and (res.Condition or res.Health or res.Durability)
                                    showWorkshopPopup(cond and "Repaired! Condition: " .. tostring(cond) .. "%" or "Repair collected!", COLORS.Green)
                                elseif action == "rollGrade" then
                                    local res = cfg.collect(slotIndex)
                                    local grade = type(res) == "table" and (res.Grade or res.Stars or res.Score)
                                    showWorkshopPopup(grade and "Graded! Stars: " .. tostring(grade) .. " ⭐" or "Grade completed!", COLORS.Gold)
                                elseif action == "openSafe" then
                                    local openRes = cfg.openSafe(slotIndex)
                                    task.wait(0.3)
                                    local claimRes = cfg.claimWork(slotIndex)
                                    local lootStr = "Unknown"
                                    local targetRes = (type(claimRes) == "table" and next(claimRes)) and claimRes or openRes
                                    if type(targetRes) == "table" then
                                        local list = targetRes.Items or targetRes.Loot or targetRes.Rewards or targetRes
                                        local items = {}
                                        for k, v in pairs(list) do
                                            local itName = type(v) == "table" and (v.ItemName or v.Name or v.ItemId) or tostring(v)
                                            if type(k) == "string" and type(v) == "table" then
                                                itName = v.ItemName or v.Name or v.ItemId or k
                                            elseif type(k) == "string" and type(v) == "string" then
                                                itName = v
                                            end
                                            local displayName = getItemData(itName)
                                            table.insert(items, displayName)
                                        end
                                        if #items > 0 then lootStr = table.concat(items, ", ") end
                                    elseif type(targetRes) == "string" then 
                                        lootStr = targetRes 
                                    end
                                    showWorkshopPopup("Safe Opened! Loot: " .. lootStr, COLORS.Orange)
                                end
                            end)
                            if not success then
                                actionBtn.Text = btnText
                            end
                            refreshWorkshopView()
                        end)
                    end)
                end
            end
        end
    end)
end

